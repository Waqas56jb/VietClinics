# VietClinics AI Chatbot — Backend Environment Variables
# Copy this file to .env and fill in your values.

# OpenAI API Key (required)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Server port (optional, defaults to 3000)
PORT=3000

# CORS — restrict which frontend origin can call this API.
# Use "*" for development (allow any origin).
# For production, set to your deployed frontend URL, e.g.
#   FRONTEND_URL=https://vietclinics.netlify.app
FRONTEND_URL=*
